# Unity Collective — Environment Variable Template
#
# Copy this file to .env.local and fill in your Firebase project values.
# .env.local is git-ignored and will NOT be committed.
#
# Vite env loading order: .env → .env.local → .env.development → .env.development.local
# .env.development sets VITE_USE_MOCK_DATA=true by default (safe for new devs).
# Override it in .env.local to use live Firebase.

# ===========================================
# DATA SOURCE CONFIGURATION
# ===========================================
# Set to 'false' to use live Firebase (requires Firebase config below).
# Set to 'true' to use local mock data (no Firebase credentials needed).
VITE_USE_MOCK_DATA=false

# ===========================================
# FIREBASE CONFIGURATION
# ===========================================
# Get these values from your Firebase project settings
# Firebase Console: https://console.firebase.google.com/
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ===========================================
# STRIPE CONFIGURATION
# ===========================================
# Get your publishable key from Stripe Dashboard
# Stripe Dashboard: https://dashboard.stripe.com/
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
